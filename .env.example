# --- Supabase Postgres ---
# Use the "Session pooler" connection string from Supabase:
# Project → Settings → Database → Connection string → "Session pooler".
# (Session pooler is needed so order-creation transactions work reliably.)
DATABASE_URL=postgres://postgres.xxxxxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Supabase Storage (photo storage, full quality, private bucket) ---
# Project → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
# SERVICE ROLE key — server-side only, NEVER expose in the browser
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
SUPABASE_STORAGE_BUCKET=photos

# --- Payment provider ---
# Which gateway to use: "comgate" (only one implemented for now)
PAYMENT_PROVIDER=comgate
COMGATE_MERCHANT=000000
COMGATE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# "true" = Comgate test/sandbox mode, "false" = live payments
COMGATE_TEST=true

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
# Verified sender domain address (must be a domain verified in Resend)
EMAIL_FROM=objednavky@fotoobrazypro.cz
# Where studio order notifications go
STUDIO_NOTIFY_EMAIL=das1979@seznam.cz

# --- App ---
# Public base URL of the deployment (no trailing slash). Used for Comgate return/notify URLs.
# Local: http://localhost:3000  |  Preview/Prod: https://your-domain
PUBLIC_BASE_URL=http://localhost:3000
